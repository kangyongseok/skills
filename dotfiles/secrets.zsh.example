# Machine-local secrets — copy this to ~/.secrets.zsh and fill in.
# ~/.secrets.zsh is git-ignored and MUST NEVER be committed.
# ~/.zshrc sources it automatically if present.

# Example — a bot/service token:
# export SLACK_BOT_TOKEN="xoxb-..."

# Example — a workflow-specific shell function (kept out of the public repo):
# deploy_beta() { vercel alias "$1" "your-private-domain.example.com"; }

# Add any tokens / private endpoints / keys / private helpers here.
